// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  DEVELOPER
  ADMIN
}

enum TemplateTier {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

enum SubscriptionPlan {
  PRO
  ENTERPRISE
}

enum AirdropStatus {
  DRAFT
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum FrameStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model User {
  id        String   @id @default(uuid())
  wallet    String   @unique
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  prompts           Prompt[]
  sessions          Session[]
  usage             Usage[]
  contracts         Contract[]
  frames            Frame[]
  templatePurchases TemplatePurchase[]
  subscriptions     Subscription[]
  airdropCampaigns  AirdropCampaign[]
  auditLogs         AuditLog[]
  paymentEvents     PaymentEvent[]
  socialGraphCache  SocialGraphCache?
}

model Prompt {
  id        String   @id @default(uuid())
  userId    String
  input     String
  optimized String
  version   Int      @default(1)
  shared    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Usage {
  id         String   @id @default(uuid())
  userId     String
  tokensUsed Int
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feed {
  id       String @id @default(uuid())
  content  String
  authorId String
  score    Int    @default(0)
}

model Contract {
  id           String   @id @default(uuid())
  address      String   @unique
  label        String?
  deployedById String
  deployedBy   User     @relation(fields: [deployedById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([deployedById])
}

// ---------------------------------------------------------------------------
// Frame Builder
// ---------------------------------------------------------------------------

model Frame {
  id          String      @id @default(uuid())
  userId      String
  title       String
  description String?
  status      FrameStatus @default(DRAFT)
  config      Json        @default("{}")
  templateId  String?
  views       Int         @default(0)
  interactions Int        @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template?   @relation(fields: [templateId], references: [id])
  events   FrameEvent[]

  @@index([userId])
  @@index([status])
}

// Tracks individual interaction events emitted by a Farcaster Frame
model FrameEvent {
  id        String   @id @default(uuid())
  frameId   String
  userId    String?  // null for unauthenticated interactions
  eventType String   // e.g. "button_click", "cast", "recast", "like", "follow"
  buttonIndex Int?
  inputText String?
  castHash  String?  // Farcaster cast hash when event originates from a cast
  fid       Int?     // Farcaster FID of the acting user
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  frame Frame @relation(fields: [frameId], references: [id], onDelete: Cascade)

  @@index([frameId])
  @@index([eventType])
  @@index([fid])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Templates
// ---------------------------------------------------------------------------

model Template {
  id          String       @id @default(uuid())
  name        String
  description String?
  category    String
  tier        TemplateTier @default(FREE)
  priceUsd    Decimal      @default(0) @db.Decimal(10, 2)
  featured    Boolean      @default(false)
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  purchases TemplatePurchase[]
  frames    Frame[]

  @@index([tier])
  @@index([category])
}

model TemplatePurchase {
  id          String   @id @default(uuid())
  userId      String
  templateId  String
  paymentRef  String?  // Stripe PaymentIntent or txHash
  amountUsd   Decimal  @db.Decimal(10, 2)
  idempotencyKey String @unique
  createdAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id])

  @@unique([userId, templateId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Subscriptions
// ---------------------------------------------------------------------------

model Subscription {
  id                 String             @id @default(uuid())
  userId             String
  stripeSubscriptionId String?          @unique
  plan               SubscriptionPlan
  status             SubscriptionStatus
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  canceledAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Airdrop Manager
// ---------------------------------------------------------------------------

model AirdropCampaign {
  id          String        @id @default(uuid())
  userId      String
  name        String
  description String?
  tokenAddress String?
  tokenSymbol  String?
  totalAmount  String?       // stored as string to avoid float precision issues
  status      AirdropStatus @default(DRAFT)
  merkleRoot  String?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipients  AirdropRecipient[]
  merkleRoots AirdropMerkleRoot[]

  @@index([userId])
  @@index([status])
}

model AirdropRecipient {
  id          String   @id @default(uuid())
  campaignId  String
  address     String
  amount      String   // stored as string to avoid float precision issues
  claimed     Boolean  @default(false)
  txHash      String?
  createdAt   DateTime @default(now())

  campaign AirdropCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, address])
  @@index([campaignId])
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------

model PaymentEvent {
  id             String   @id @default(uuid())
  userId         String?
  stripeEventId  String?  @unique
  eventType      String
  payload        Json
  processed      Boolean  @default(false)
  processedAt    DateTime?
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([eventType])
}

// ---------------------------------------------------------------------------
// Audit Logs
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  resource  String?
  resourceId String?
  metadata  Json     @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Social Graph Cache
// ---------------------------------------------------------------------------

// Cached Farcaster social graph snapshot for a user (refreshed via background job)
model SocialGraphCache {
  id           String   @id @default(uuid())
  userId       String   @unique
  fid          Int      @unique
  followingFids Int[]   // FIDs this user follows
  followerFids  Int[]   // FIDs that follow this user
  mutualFids    Int[]   // intersection of following + followers
  lastSyncedAt DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fid])
}

// ---------------------------------------------------------------------------
// Airdrop Merkle Roots
// ---------------------------------------------------------------------------

// Immutable record of each merkle root published for an airdrop campaign.
// Multiple roots may exist per campaign (e.g. after adding late recipients).
model AirdropMerkleRoot {
  id         String   @id @default(uuid())
  campaignId String
  merkleRoot String
  ipfsCid    String?  // IPFS CID of the full recipient list used to generate the root
  leafCount  Int
  txHash     String?  // on-chain transaction that anchored this root (if applicable)
  publishedAt DateTime @default(now())

  campaign AirdropCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, merkleRoot])
  @@index([campaignId])
}
