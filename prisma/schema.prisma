// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  DEVELOPER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  wallet    String   @unique
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  prompts   Prompt[]
  sessions  Session[]
  usage     Usage[]
  contracts Contract[]
}

model Prompt {
  id        String   @id @default(uuid())
  userId    String
  input     String
  optimized String
  version   Int      @default(1)
  shared    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Usage {
  id         String   @id @default(uuid())
  userId     String
  tokensUsed Int
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feed {
  id       String @id @default(uuid())
  content  String
  authorId String
  score    Int    @default(0)
}

model Contract {
  id           String   @id @default(uuid())
  address      String   @unique
  label        String?
  deployedById String
  deployedBy   User     @relation(fields: [deployedById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([deployedById])
}
