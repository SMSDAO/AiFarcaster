# WalletConnect Configuration
# Get your project ID from https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Stripe Configuration (Required for payments)
# Get your API keys from https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_... and sk_test_...) for development
# Use live keys (pk_live_... and sk_live_...) for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (server-side only — copy from Stripe Dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_PREMIUM_TEMPLATE=price_...

# Crypto Payment Configuration (Optional)
# Your wallet address to receive crypto payments on Base
NEXT_PUBLIC_PAYMENT_RECEIVER_ADDRESS=0x...

# Application URL (Required for production)
NEXT_PUBLIC_URL=http://localhost:3000

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Farcaster Hub Configuration
# Default: public hub at nemes.farcaster.xyz:2283
FARCASTER_HUB_URL=nemes.farcaster.xyz:2283
# Set to "testnet" to target a testnet/dev hub (defaults to mainnet)
# FARCASTER_NETWORK=testnet
# Server-held Ed25519 signer private key (32-byte hex, no 0x prefix)
# IMPORTANT: Never share or commit this value
FARCASTER_SIGNER_PRIVATE_KEY=

# PostgreSQL Database (Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/aifarcaster

# OpenAI API Key (for AI Prompt Optimizer)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Upstash Redis (for rate limiting)
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Firebase Realtime Database (for realtime prompt sync)
# https://console.firebase.google.com/
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Monitoring
# Protects GET /api/monitoring — set to a long random string
MONITORING_SECRET=

# Feature Flags (set to "true" to enable)
# Token Launcher is disabled until security audit completes
FEATURE_TOKEN_LAUNCHER=false
# Crypto payments are disabled until production security review completes
FEATURE_CRYPTO_PAYMENTS=false

# Deployment
# Set to "true" to enable Next.js standalone output (for Docker / self-hosted)
NEXT_OUTPUT_STANDALONE=false
